CONFIG_IDF_TARGET="esp32p4"
CONFIG_BSP_TARGET_TANMATSU=y
CONFIG_BSP_LVGL_DSI_DISPLAY=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
CONFIG_LV_CACHE_DEF_SIZE=1280000
CONFIG_ESP_SYSTEM_PANIC_PRINT_HALT=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=n
CONFIG_BT_NIMBLE_TRANSPORT_UART=n
CONFIG_ESP_WIFI_IRAM_OPT=y
CONFIG_ESP_WIFI_RX_IRAM_OPT=y
CONFIG_BSP_LVGL_DSI_DISPLAY=y
CONFIG_ESP_SDIO_PIN_CMD=16
CONFIG_ESP_SDIO_PIN_CLK=17
CONFIG_ESP_SDIO_PIN_D0=18
CONFIG_ESP_SDIO_PIN_D1=19
CONFIG_ESP_SDIO_PIN_D2=20
CONFIG_ESP_SDIO_PIN_D3=21
CONFIG_ESP_SDIO_GPIO_RESET_SLAVE=-1
# ESP-Hosted SDIO pins (must match tanmatsu board wiring)
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=16
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=17
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=18
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=19
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=20
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=21
CONFIG_ESP_HOSTED_SDIO_RESET_SLAVE_USING_CALLBACK=y
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_ENABLE_BT_NIMBLE=y
CONFIG_TINYUSB_RHPORT_FS=y
CONFIG_TINYUSB_VENDOR_COUNT=1
CONFIG_CUSTOM_CA_TANMATSU_APPS=y
CONFIG_CUSTOM_CA_TANMATSU_OTA=y
CONFIG_LCD_DSI_ISR_IRAM_SAFE=y

# Console
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# Matter controller / commissioner
# WiFi stack is managed by tanmatsu wifi-manager, not by CHIP
CONFIG_ENABLE_WIFI_STATION=n
CONFIG_ENABLE_CHIP_CONTROLLER_BUILD=y
CONFIG_ESP_MATTER_CONTROLLER_ENABLE=y
CONFIG_ESP_MATTER_COMMISSIONER_ENABLE=y
CONFIG_ENABLE_ESP32_BLE_CONTROLLER=y
CONFIG_CHIP_TASK_STACK_SIZE=15360
CONFIG_ESP_MAIN_TASK_STACK_SIZE=10240
CONFIG_NUM_UDP_ENDPOINTS=16
CONFIG_MBEDTLS_HKDF_C=y
CONFIG_LWIP_IPV6_NUM_ADDRESSES=12
CONFIG_CHIP_PROJECT_CONFIG="main/matter_project_config.h"
CONFIG_ESP_MATTER_ENABLE_MATTER_SERVER=n
CONFIG_ENABLE_CHIP_SHELL=n

# OpenThread Border Router (ESP32-C6 RCP via Spinel UART)
# C6 LP_UART TX (net E8) → P4 GPIO54, C6 LP_UART RX (net E10) ← P4 GPIO53
CONFIG_OPENTHREAD_ENABLED=y
CONFIG_OPENTHREAD_BORDER_ROUTER=y
CONFIG_OPENTHREAD_LOG_LEVEL_DYNAMIC=n
CONFIG_OPENTHREAD_LOG_LEVEL_NOTE=y
CONFIG_OPENTHREAD_SRP_CLIENT=n
CONFIG_OPENTHREAD_DNS_CLIENT=n
CONFIG_THREAD_NETWORK_COMMISSIONING_DRIVER=n
CONFIG_LWIP_IPV6_FORWARD=y
CONFIG_LWIP_IPV6_AUTOCONFIG=y
CONFIG_LWIP_MULTICAST_PING=y
CONFIG_LWIP_NETIF_STATUS_CALLBACK=y
CONFIG_LWIP_HOOK_IP6_ROUTE_DEFAULT=y
CONFIG_LWIP_HOOK_ND6_GET_GW_DEFAULT=y
CONFIG_LWIP_HOOK_IP6_INPUT_CUSTOM=y
CONFIG_LWIP_HOOK_IP6_SELECT_SRC_ADDR_CUSTOM=y
CONFIG_ENABLE_ROUTE_HOOK=n
CONFIG_MBEDTLS_KEY_EXCHANGE_ECJPAKE=y
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_ECJPAKE_C=y
CONFIG_THREAD_TASK_STACK_SIZE=8192
CONFIG_USE_MINIMAL_MDNS=n
